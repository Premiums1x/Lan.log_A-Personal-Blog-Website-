# Copy this file to .env and edit the values.
HTTP_ADDR=:8080
DATABASE_URL=postgres://blog:blog@localhost:5432/blog?sslmode=disable
JWT_SECRET=dev-secret-change-me-please-32bytes!
JWT_TTL_HOURS=72

# Only used when the first admin user is created.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=your-qq-number@qq.com

# QQ Mail SMTP for password reset codes.
# SMTP_PASSWORD must be the QQ Mail authorization code, not your QQ login password.
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-qq-number@qq.com
SMTP_PASSWORD=your-qq-mail-authorization-code
SMTP_FROM=your-qq-number@qq.com
# Optional OpenAI-compatible API used to generate article excerpts.
# LLM_API_URL must be the full chat-completions endpoint.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=20