{{template "layout" .}}

{{define "title"}}{{.Post.Title}} — {{$.Site.Brand.Brand}}{{end}}

{{define "content"}}
<header class="art-hero">
  <div class="art-hero-inner reveal">
    <div class="art-crumbs">
      <a href="/">~/posts</a>
      <span class="sep">/</span>
      <a href="/section/{{.Post.Section}}">{{.Post.Section}}</a>
      <span class="sep">/</span>
      <span>{{.Post.Slug}}.md</span>
    </div>
    <h1 class="art-h1">{{RenderInline .Post.Title}}</h1>
    {{if .Post.Excerpt}}<p class="art-lede">{{.Post.Excerpt}}</p>{{end}}
    <div class="art-meta">
      <span class="avatar">{{FirstChar .AuthorName}}</span>
      <span class="v">{{.AuthorName}}</span>
      <span class="sep">·</span>
      <span class="k">published</span><span class="v">{{FormatDate .Post.PublishedAt}}</span>
      <span class="sep">·</span>
      <span class="k">read</span><span class="v">{{.Post.ReadMinutes}} min</span>
      <span class="sep">·</span>
      <span class="k">words</span><span class="v">{{.Post.Words}}</span>
      <span class="sep">·</span>
      <span class="k">commit</span><span class="v">{{CommitShort .Post.CommitHash}}</span>
    </div>
  </div>
</header>

<main class="article-page">
  <article class="article-paper reveal" id="article-paper" aria-label="{{.Post.Title}}">
  <svg class="art-trace" id="art-trace-svg" aria-hidden="true" preserveAspectRatio="none">
    <path id="trace-path" class="trace-path" d=""/>
  </svg>
    {{if .Post.CoverURL}}
    <div class="art-cover">
      <img src="{{.Post.CoverURL}}" alt="{{.Post.Title}}">
    </div>
    {{end}}
    <div class="art-body" id="art-body">
      {{RenderHTML .Post.BodyHTML}}
    </div>
  </article>
</main>

<section class="art-end reveal">
  <div class="art-tags">
    {{range .Post.Tags}}<a class="tag" href="/tags/{{.Slug}}">{{.Name}}</a>{{end}}
  </div>
  {{if .Heatmap}}
  <div class="gh-heatmap" id="gh-heatmap">
    <div class="gh-heatmap-head">
      <span class="gh-label">{{.Heatmap.Total}} contributions in the last year</span>
    </div>
    <div class="gh-grid">
      {{range .Heatmap.Weeks}}
      <div class="gh-week">
        {{range .}}<div class="gh-cell l{{.Level}}" data-d="{{.Date}}" data-c="{{.Count}}" tabindex="0" role="img" aria-label="{{.Date}} · {{.Count}} contributions"></div>{{end}}
      </div>
      {{end}}
    </div>
    <div class="gh-heatmap-foot">
      <a href="{{.Heatmap.URL}}" target="_blank" rel="noopener">@{{.Heatmap.Username}}</a>
      <span class="gh-sep">·</span>
      <a href="{{.Heatmap.URL}}" target="_blank" rel="noopener">github.com/{{.Heatmap.Username}} →</a>
    </div>
    <div class="gh-scroll" id="gh-scroll" aria-hidden="true">
      <div class="gh-scroll-track" id="gh-scroll-track">
        <div class="gh-scroll-thumb" id="gh-scroll-thumb"></div>
      </div>
    </div>
    <div class="gh-tip" id="gh-tip" aria-hidden="true">
      <span class="gh-tip-date">&nbsp;</span>
      <span class="gh-tip-count">&nbsp;</span>
    </div>
  </div>
  <script>
  (function(){
    var heatmap = document.getElementById('gh-heatmap');
    var tip = document.getElementById('gh-tip');
    if (!heatmap || !tip) return;
    var dEl = tip.querySelector('.gh-tip-date');
    var cEl = tip.querySelector('.gh-tip-count');
    var showTimer = null, hideTimer = null;
    function fmtDate(s){
      var m = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var p = s.split('-'); return m[(+p[1]-1)||0] + ' ' + (+p[2]) + ', ' + p[0];
    }
    function show(cell){
      clearTimeout(hideTimer);
      dEl.textContent = fmtDate(cell.dataset.d || '');
      var n = +cell.dataset.c || 0;
      cEl.textContent = n + (n === 1 ? ' contribution' : ' contributions');
      var hr = heatmap.getBoundingClientRect();
      var cr = cell.getBoundingClientRect();
      tip.style.left = (cr.left - hr.left + cr.width/2) + 'px';
      tip.style.top  = (cr.top  - hr.top ) + 'px';
      tip.classList.add('is-show');
      tip.setAttribute('aria-hidden','false');
    }
    function hide(){
      showTimer && clearTimeout(showTimer);
      hideTimer = setTimeout(function(){
        tip.classList.remove('is-show');
        tip.setAttribute('aria-hidden','true');
      }, 90);
    }
    heatmap.addEventListener('mouseover', function(e){
      var cell = e.target.closest && e.target.closest('.gh-cell');
      if (cell) show(cell);
    });
    heatmap.addEventListener('mouseout', function(e){
      var cell = e.target.closest && e.target.closest('.gh-cell');
      if (cell) hide();
    });
    heatmap.addEventListener('focusin', function(e){
      var cell = e.target.closest && e.target.closest('.gh-cell');
      if (cell) show(cell);
    });
    heatmap.addEventListener('focusout', function(e){
      var cell = e.target.closest && e.target.closest('.gh-cell');
      if (cell) hide();
    });

    // ─── custom scrollbar synced to grid scroll ───
    var grid = heatmap.querySelector('.gh-grid');
    var scroll = document.getElementById('gh-scroll');
    var track  = document.getElementById('gh-scroll-track');
    var thumb  = document.getElementById('gh-scroll-thumb');
    if (grid && track && thumb) {
      var ratio = 0;
      function update() {
        var max = grid.scrollWidth - grid.clientWidth;
        if (max <= 0) { scroll.style.display = 'none'; return; }
        scroll.style.display = '';
        ratio = grid.scrollLeft / max;
        var tw = track.clientWidth - thumb.offsetWidth;
        thumb.style.left = (ratio * tw) + 'px';
      }
      grid.addEventListener('scroll', function(){
        update();
        scroll.classList.remove('flash');
      }, { passive: true });
      grid.addEventListener('wheel', function(){ scroll.classList.add('flash'); clearTimeout(scroll._f); scroll._f = setTimeout(function(){ scroll.classList.remove('flash'); }, 700); }, { passive: true });
      var dragging = false;
      track.addEventListener('pointerdown', function(e){
        dragging = true; scroll.classList.add('dragging'); e.preventDefault();
        jump(e);
      });
      window.addEventListener('pointermove', function(e){ if (dragging) jump(e); });
      window.addEventListener('pointerup', function(){ if (dragging) { dragging = false; scroll.classList.remove('dragging'); } });
      function jump(e){
        var r = track.getBoundingClientRect();
        var p = (e.clientX - r.left) / r.width;
        if (p < 0) p = 0; if (p > 1) p = 1;
        var max = grid.scrollWidth - grid.clientWidth;
        grid.scrollTo({ left: p * max, behavior: 'smooth' });
      }
      update();
      window.addEventListener('resize', update);
    }
  })();
  </script>
  {{end}}
</section>

{{if or .Prev .Next}}
<nav class="art-pn reveal">
  {{if .Prev}}<a class="pn-card" href="/posts/{{.Prev.Slug}}">
    <div class="pn-label">← prev · {{CommitShort .Prev.CommitHash}}</div>
    <div class="pn-title">{{.Prev.Title}}</div>
  </a>{{else}}<div></div>{{end}}
  {{if .Next}}<a class="pn-card next" href="/posts/{{.Next.Slug}}">
    <div class="pn-label">{{CommitShort .Next.CommitHash}} · next →</div>
    <div class="pn-title">{{.Next.Title}}</div>
  </a>{{else}}<div></div>{{end}}
</nav>
{{end}}
<script>
(function(){
  var paper = document.getElementById('article-paper');
  if (!paper) return;
  var svg = paper.querySelector('#art-trace-svg');
  var path = paper.querySelector('#trace-path');
  if (!svg || !path) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) return;

  var SEG = 160;
  var R  = 16;       /* corner radius */
  var Rm = 1;        /* path inset to keep stroke fully visible */
  var Rr = R - Rm;   /* arc radius on the path */
  var MOVE_INTERVAL = 120;
  var POSITION_STEP = 36;
  var EDGE_ZONE = 80;
  var EDGE_HYSTERESIS = 20;
  var moveTimer = null, pending = null;
  var scrolling = false, scrollIdle = null;
  var activeEdge = null, currentOffset = null;
  var peri = 0;

  function buildPath(){
    var r = paper.getBoundingClientRect();
    var W = r.width, H = r.height;
    svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);
    var P = 'M ' + R  + ' ' + Rm + ' '
      + 'H ' + (W - R) + ' '
      + 'A ' + Rr + ' ' + Rr + ' 0 0 1 ' + (W - Rm)  + ' ' + R        + ' '
      + 'V ' + (H - R) + ' '
      + 'A ' + Rr + ' ' + Rr + ' 0 0 1 ' + (W - R)   + ' ' + (H - Rm) + ' '
      + 'H ' + R + ' '
      + 'A ' + Rr + ' ' + Rr + ' 0 0 1 ' + Rm        + ' ' + (H - R) + ' '
      + 'V ' + R + ' '
      + 'A ' + Rr + ' ' + Rr + ' 0 0 1 ' + R         + ' ' + Rm      + ' '
      + 'Z';
    path.setAttribute('d', P);
    peri = path.getTotalLength();
    currentOffset = null;
    path.style.strokeDasharray = SEG + ' ' + (peri - SEG);
  }

  function nearestEdge(x, y, W, H){
    var distances = { top: y, right: W - x, bottom: H - y, left: x };
    var edge = 'top';
    ['right', 'bottom', 'left'].forEach(function(name){
      if (distances[name] < distances[edge]) edge = name;
    });
    if (distances[edge] > EDGE_ZONE) return null;
    if (activeEdge && edge !== activeEdge) {
      var activeDistance = distances[activeEdge];
      var advantage = activeDistance - distances[edge];
      if (activeDistance <= EDGE_ZONE && advantage < EDGE_HYSTERESIS) {
        edge = activeEdge;
      }
    }
    activeEdge = edge;
    return edge;
  }

  /* 周长坐标: 从 path 起点 (R, Rm) 顺时针走。 */
  function project(x, y, W, H, edge){
    var arcL = Math.PI / 2 * Rr;
    var topLen = W - 2 * R;
    var rightLen = H - 2 * R;
    var bottomLen = topLen;
    var cTop = arcL;
    var cRight = cTop + topLen + arcL;
    var cBot = cRight + rightLen + arcL;
    var cLeft = cBot + bottomLen + arcL;
    var xx, yy;
    if (edge === 'top') {
      xx = Math.max(R, Math.min(W - R, x));
      return cTop + (xx - R);
    }
    if (edge === 'right') {
      yy = Math.max(R, Math.min(H - R, y));
      return cRight + (yy - R);
    }
    if (edge === 'bottom') {
      xx = Math.max(R, Math.min(W - R, x));
      return cBot + ((W - R) - xx);
    }
    yy = Math.max(R, Math.min(H - R, y));
    return cLeft + ((H - R) - yy);
  }

  function unwrapOffset(off){
    if (currentOffset === null) {
      currentOffset = off;
      return off;
    }
    off += Math.round((currentOffset - off) / peri) * peri;
    currentOffset = off;
    return off;
  }
  function schedule(x, y, W, H){
    if (scrolling) return;
    pending = [x, y, W, H];
    if (moveTimer) return;
    moveTimer = setTimeout(function(){
      moveTimer = null;
      if (!pending) return;
      var p = pending; pending = null;
      var edge = nearestEdge(p[0], p[1], p[2], p[3]);
      if (!edge) {
        activeEdge = null;
        paper.classList.remove('art-on');
        return;
      }
      var t = project(p[0], p[1], p[2], p[3], edge);
      t = Math.round(t / POSITION_STEP) * POSITION_STEP;
      /* 让 dash 中心对齐吸附后的边框位置 */
      var off = (peri - (t - SEG / 2)) % peri;
      if (off < 0) off += peri;
      path.style.strokeDashoffset = unwrapOffset(off) + 'px';
      paper.classList.add('art-on');
    }, MOVE_INTERVAL);
  }
  paper.addEventListener('mouseenter', function(){
    if (!peri) buildPath();
  });
  paper.addEventListener('mousemove', function(e){
    var r = paper.getBoundingClientRect();
    schedule(e.clientX - r.left, e.clientY - r.top, r.width, r.height);
  });
  paper.addEventListener('mouseleave', function(){
    paper.classList.remove('art-on');
    if (moveTimer) { clearTimeout(moveTimer); moveTimer = null; }
    pending = null;
    activeEdge = null;
  });
  window.addEventListener('scroll', function(){
    scrolling = true;
    if (moveTimer) { clearTimeout(moveTimer); moveTimer = null; }
    pending = null;
    clearTimeout(scrollIdle);
    scrollIdle = setTimeout(function(){ scrolling = false; }, 160);
  }, { passive: true });
  window.addEventListener('resize', function(){
    if (peri) buildPath();
  });
})();
</script>
<script>
(function(){
  var body = document.getElementById('art-body');
  if (!body) return;
  var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) return;
  if (!('IntersectionObserver' in window)) return;
  var kids = Array.prototype.slice.call(body.children);
  kids.forEach(function(el){ el.classList.add('prose-rise'); });
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) {
        e.target.style.animationDelay = Math.min((e.target.dataset.i||0)*40, 240) + 'ms';
        e.target.classList.add('prose-in');
        io.unobserve(e.target);
      }
    });
  }, { rootMargin: '0px 0px -12% 0px', threshold: 0.08 });
  kids.forEach(function(el, i){ el.dataset.i = i; io.observe(el); });
})();
</script>
{{end}}