{{template "layout" .}}

{{define "title"}}loadout - {{$.Site.Brand.Brand}}{{end}}

{{define "content"}}
<main class="lancer-page lancer-loadout">
  <header class="lancer-page-hero loadout-hero cinematic-stage runway-stage shelf-stage page-opening">
    <div class="cinematic-image" aria-hidden="true"></div>
    <div class="page-poster-word" aria-hidden="true">LOADOUT</div>
    <div class="page-hero-copy reveal">
      <div class="lancer-kicker"><span>LOADOUT</span><i></i><span>TOOLS / STORIES / SIGNALS</span></div>
      <p class="page-command"><span>lancer@field-notes:~$</span> ls ./loadout --group-by=signal</p>
      <h1>带进下一回合的，<br><em>不只有代码。</em></h1>
      <p>{{.Shelf.Intro}}</p>
    </div>
    <div class="loadout-terminal loadout-slots reveal">
      <div class="dev-editor-head"><span><i></i><i></i><i></i></span><strong>loadout.sh</strong><b>bash</b></div>
      <p><i>$</i> ls ./loadout</p>
      <div class="loadout-output"><span>01&nbsp; engineering/</span><span>02&nbsp; stories/</span><span>03&nbsp; competition/</span><span>04&nbsp; soundtrack/</span></div>
      <p class="terminal-ok">4 directories&nbsp;&nbsp; 0 reasons to stop</p>
      <strong>ACTIVE DECK</strong>
    </div>
    <a class="drawer-cue" href="#shelf-drawer" data-drawer-target="shelf-drawer" aria-label="继续向下浏览">
      <span>SCROLL TO OPEN</span><b aria-hidden="true">↓</b>
    </a>
  </header>
  <div class="page-drawer" id="shelf-drawer">
  <section class="loadout-wrap">
    <div class="loadout-title reveal">
      <div class="lancer-section-index"><span>01</span><p>INFLUENCE DECK</p></div>
      <h2>我正在使用、阅读，或反复回去寻找力量的东西。</h2>
    </div>

    {{range $groupIndex, $group := .Shelf.Groups}}
    <section class="loadout-group reveal">
      <header>
        <span>DECK / 0{{$groupIndex}}</span>
        <h2>{{$group.Title}}</h2>
        <p>{{$group.Desc}}</p>
      </header>
      <div class="loadout-grid">
        {{range $itemIndex, $item := $group.Items}}
        {{if $item.Href}}<a class="loadout-card" href="{{$item.Href}}" target="_blank" rel="noreferrer">{{else}}<article class="loadout-card">{{end}}
          <div class="loadout-card-top"><span>SLOT / 0{{$itemIndex}}</span><strong>{{$item.Status}}</strong></div>
          <div class="loadout-card-copy"><p>{{$item.Meta}}</p><h3>{{$item.Title}}</h3><div class="loadout-drawer">{{$item.Desc}}</div></div>
          <div class="loadout-tags">{{range $item.Tags}}<span>{{.}}</span>{{end}}<b>↗</b></div>
        {{if $item.Href}}</a>{{else}}</article>{{end}}
        {{end}}
      </div>
    </section>
    {{else}}<p class="lancer-empty">LOADOUT EMPTY / 从管理后台添加新的影响来源。</p>{{end}}
  </section>
  </div>
</main>
{{end}}