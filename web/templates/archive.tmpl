{{template "layout" .}}

{{define "title"}}{{if .FilterLabel}}{{.FilterLabel}} - {{end}}season log - {{$.Site.Brand.Brand}}{{end}}

{{define "content"}}
<main class="lancer-page lancer-archive">
  <header class="lancer-page-hero archive-cockpit cinematic-stage runway-stage archive-stage page-opening">
    <div class="cinematic-image" aria-hidden="true"></div>
    <div class="page-poster-word" aria-hidden="true">SEASONS</div>
    <div class="page-hero-copy reveal">
      <div class="lancer-kicker"><span>SEASON LOG</span><i></i><span>ALL ROUNDS / RECORDED</span></div>
      <p class="page-command"><span>lancer@field-notes:~$</span> git log --all --oneline --stat</p>
      <h1>{{if .FilterLabel}}{{.FilterLabel}}{{else}}走过的路线，<br><em>不会白费。</em>{{end}}</h1>
      <p>{{.Archive.Intro}}</p>
    </div>
    <div class="archive-scoreboard archive-terminal reveal">
      <div class="dev-editor-head"><span><i></i><i></i><i></i></span><strong>git log --all</strong><b>main</b></div>
      <p class="archive-terminal-line"><i>HEAD → main</i> chore: keep moving when the route is unclear</p>
      <div><span>FIELD NOTES</span><strong>{{.TotalPosts}}</strong></div>
      <div><span>WORDS LOGGED</span><strong>{{.TotalWords}}</strong></div>
      <div><span>ORDER</span><strong>NEWEST</strong></div>
    </div>
    <a class="drawer-cue" href="#archive-drawer" data-drawer-target="archive-drawer" aria-label="继续向下浏览">
      <span>SCROLL TO OPEN</span><b aria-hidden="true">↓</b>
    </a>
  </header>
  <div class="page-drawer" id="archive-drawer">
  <section class="season-layout">
    <aside class="race-control reveal">
      <div class="race-control-head"><span>RACE CONTROL</span><i>LIVE</i></div>
      <div class="control-block">
        <h2>SECTIONS</h2>
        <a href="/archive"><span>ALL FIELD NOTES</span><b>{{.TotalPosts}}</b></a>
        {{range .Sections}}<a href="/section/{{.Slug}}"><span>{{.Name}}</span><b>{{.Count}}</b></a>{{end}}
      </div>
      <div class="control-block">
        <h2>TAGS</h2>
        <div class="control-tags">{{range .Tags}}<a href="/tags/{{.Slug}}">#{{.Name}} <b>{{.Count}}</b></a>{{end}}</div>
      </div>
    </aside>

    <div class="season-main reveal">
      {{if .FilterLabel}}<div class="season-filter"><span>{{.FilterKind}}</span><strong>{{.FilterLabel}}</strong><a href="/archive">CLEAR FILTER ×</a></div>{{end}}
      <div class="season-line">
        {{range .Years}}
        <section class="season-year">
          <header><span>SEASON</span><h2>{{.Year}}</h2><i></i></header>
          <div class="season-notes">
            {{range .Posts}}
            <a class="season-note" href="/posts/{{.Slug}}">
              <div class="season-note-meta"><span>{{FormatDate .PublishedAt}}</span><span>{{CommitShort .CommitHash}}</span></div>
              <div class="season-note-copy"><h3>{{.Title}}</h3>{{if .Excerpt}}<p>{{.Excerpt}}</p>{{end}}<div>{{range .Tags}}<span>#{{.Name}}</span>{{end}}</div></div>
              <div class="season-note-read"><span>{{.ReadMinutes}} MIN</span><b>↗</b></div>
            </a>
            {{end}}
          </div>
        </section>
        {{else}}<p class="lancer-empty">{{.EmptyText}}</p>{{end}}
      </div>
    </div>
  </section>
  </div>
</main>
{{end}}