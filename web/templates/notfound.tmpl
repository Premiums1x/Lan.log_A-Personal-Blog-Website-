{{template "layout" .}}

{{define "title"}}404 — {{$.Site.Brand.Brand}}{{end}}

{{define "content"}}
<header class="hero" style="min-height:72dvh;">
  <div class="reveal">
    <div class="hero-eyebrow">
      <span class="prompt">$</span>
      <span class="cmd">cd {{.Path}}</span>
      <span class="blink"></span>
    </div>
    <h1 class="hero-title">没有这个路径。<br><span class="muted">// 404 · not found</span></h1>
    <p class="hero-sub">这个地址要么从未存在，要么像被 rewrite 掉的 commit 一样消失在历史里。回首页继续读吧。</p>
    <div class="hero-meta" style="margin-top:2.25rem;">
      <a href="/" class="stat" style="gap:0.4rem;"><span class="dot"></span><span class="k">cd</span><span class="v">~/</span></a>
    </div>
  </div>
</header>
{{end}}